---
import { ChevronsDown } from "lucide-astro";
---

<section
  class="relative flex h-[45vh] max-h-[1900px] shrink-0 flex-col items-center justify-center text-white sm:h-[100vh]"
>
  <video
    class="absolute -z-10 h-full w-full object-cover"
    muted
    autoplay
    loop
    disablepictureinpicture
    playsinline
  >
    <source src="/bg-video.mp4" type="video/mp4" />
  </video>

  <a href="#main" class="absolute bottom-4 animate-bounce" title="Scroll down">
    <ChevronsDown size="48" class="text-black" />
  </a>
</section>
