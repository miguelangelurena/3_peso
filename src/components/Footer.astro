---
import { Instagram, Twitter, Youtube } from "lucide-astro";
import { Mail } from "lucide-react";

import FooterItem from "./FooterItem.astro";
---

<footer class="bg-dark text-white">
  <section class="container mx-auto max-w-7xl px-6 py-8">
    <div
      class="flex flex-col items-center justify-between space-y-6 md:flex-row md:space-y-0"
    >
      <div class="flex w-full justify-center md:w-auto">
        <img
          class="w-30 h-auto md:size-12"
          src="/colorful3.svg"
          alt="3Peso's logo"
        />
      </div>
      <div class="flex space-x-6">
        <FooterItem href="mailto:3pesotvshow@gmail.com">
          <Mail className="size-4" slot="icon" />
          <span slot="text">Email</span>
        </FooterItem>
        <FooterItem href="https://instagram.com/3peso">
          <Instagram className="size-4" slot="icon" />
          <span slot="text">Instagram</span>
        </FooterItem>
        <FooterItem href="https://youtube.com/@3peso">
          <Youtube className="size-4" slot="icon" />
          <span slot="text">Youtube</span>
        </FooterItem>
        <FooterItem href="https://x.com/3pesotv">
          <Twitter className="size-4" slot="icon" />
          <span slot="text">Twitter</span>
        </FooterItem>
      </div>
    </div>
    <div class="mt-6">
      <div class="mb-2 text-center md:mb-0 md:text-left">
        <p class="text-sm text-gray-200 opacity-80">
          ©2025 3Peso. Todos los derechos reservados.
        </p>
      </div>
      <div class="text-center">
        <div class="space-x-2 text-xs">
          <a href="/privacy-policy" class="hover:text-white hover:underline">
            Política de Privacidad
          </a>
          <span class="text-gray-200 opacity-80"> | </span>
          <a
            href="/terms-and-conditions"
            class="hover:text-white hover:underline"
          >
            Términos y Condiciones
          </a>
        </div>

        <span class="text-sm text-gray-200 opacity-80">
          <a
            href="https://zitdevs.com"
            target="_blank"
            class="hover:text-white hover:underline"
          >
            En Colaboración con <span class="text-[#ff9977] underline"
              >ZitDevs</span
            ></a
          >
        </span>
      </div>
    </div>
  </section>
</footer>
