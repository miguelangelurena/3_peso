---
import { ArrowRight } from "lucide-react";
---

<head>
  <link
    href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />
</head>

<section
  class="relative h-screen w-full px-8 md:h-[75vh] lg:h-screen"
  id="casting"
>
  <img
    src="/casting-background.jpg"
    alt="Descripción de la imagen"
    class="absolute inset-0 h-full w-full object-cover opacity-20"
  />

  <div
    class="relative z-10 flex h-full flex-col items-center justify-center text-center"
  >
    <h2
      class="m-4 max-w-80 border-2 p-4 font-cursive text-3xl font-bold text-white md:text-4xl lg:text-5xl"
    >
      ¿Quieres estar en un video?
    </h2>
    <p class="mt-4 max-w-md text-base text-white md:text-xl">
      ¡Asegúrate de suscribirte a nuestro boletín de casting para no perder
      ninguna oportunidad!
    </p>
    <div class="mt-9">
      <a
        href="https://www.instagram.com/3peso/"
        target="_blank"
        class="group relative isolation-auto z-10 mx-auto flex items-center justify-center gap-2 overflow-hidden rounded-md border-2 border-white bg-dark p-2 px-6 text-white shadow-xl backdrop-blur-md before:absolute before:-left-full before:-z-10 before:aspect-square before:w-full before:rounded-full before:bg-white before:transition-all before:duration-300 hover:text-dark before:hover:left-0 before:hover:w-full before:hover:scale-150 before:hover:duration-300 lg:font-semibold"
      >
        Casting
        <ArrowRight
          className="size-5 justify-end text-gray-50 duration-100 ease-linear group-hover:text-dark"
        />
      </a>
    </div>
  </div>

  <div class="absolute inset-0 bg-black bg-opacity-50"></div>
</section>
